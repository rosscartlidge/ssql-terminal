FROM --platform=i386 i386/debian:bookworm
ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get clean && apt-get update && apt-get -y upgrade
RUN apt-get -y install bash-completion less vim curl file jq openssh-client iputils-ping
RUN useradd -m user && echo "user:password" | chpasswd
# Copy pre-built ssql binary (cross-compiled for linux/386)
COPY dockerfiles/ssql /usr/local/bin/ssql
RUN chmod +x /usr/local/bin/ssql
# Copy sample data (same files as the WASM playground)
COPY dockerfiles/data/ /home/user/data/
RUN mv /home/user/data/examples.sh /home/user/examples.sh
RUN chmod +x /home/user/examples.sh
RUN chown -R user:user /home/user/data /home/user/examples.sh
# SSH config for Tailscale hosts — user adds their IP/hostname
COPY dockerfiles/ssh_config /home/user/.ssh/config
RUN chmod 700 /home/user/.ssh && chmod 600 /home/user/.ssh/config && chown -R user:user /home/user/.ssh
# Generate SSH keypair on first boot if missing
RUN echo '[ -f ~/.ssh/id_ed25519 ] || { ssh-keygen -t ed25519 -N "" -f ~/.ssh/id_ed25519 -q; echo "SSH key generated — add to your host with:"; echo "  ssh-copy-id myhost"; echo ""; }' >> /home/user/.bashrc
# Set up bash completion for ssql
RUN echo 'eval "$(ssql -completion-script)"' >> /home/user/.bashrc
# Welcome message
RUN echo 'echo "ssql terminal ($(ssql version 2>&1)) — type: ssql from data/employees.csv | ssql to table"' >> /home/user/.bashrc
RUN echo 'echo "Examples: cat examples.sh    Tab completion: ssql from csv data/employees.csv | ssql where -if <TAB>"' >> /home/user/.bashrc
RUN echo 'echo ""' >> /home/user/.bashrc
WORKDIR /home/user/
ENV HOME="/home/user" TERM="xterm" USER="user" SHELL="/bin/bash" EDITOR="vim" LANG="en_US.UTF-8" LC_ALL="C"
RUN echo 'root:password' | chpasswd
CMD [ "/bin/bash" ]
